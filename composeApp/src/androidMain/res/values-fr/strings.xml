<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Notification : service foreground de détection -->
    <string name="notif_detection_title">Détection de stationnement active</string>
    <string name="notif_detection_text">Je détecte quand vous vous garez · toucher pour gérer</string>
    <!-- %1$s = nom du véhicule (ex. "Ford Focus") -->
    <string name="notif_detection_text_vehicle">Attentif à votre %1$s · toucher pour gérer</string>
    <string name="notif_detection_explainer">Je détecte automatiquement quand vous vous garez pour libérer votre place pour la communauté. Consommation de batterie minimale.</string>

    <!-- Notification : confirmation de stationnement -->
    <string name="notif_confirmation_title">Êtes-vous garé ?</string>
    <string name="notif_confirmation_title_vehicle">Avez-vous garé votre %1$s ?</string>
    <string name="notif_confirmation_text">Il semble que vous vous soyez garé. Voulez-vous confirmer la place ?</string>
    <string name="notif_action_yes_parked">Oui, je suis garé</string>
    <string name="notif_action_no_not_parked">Non, je ne me suis pas garé</string>

    <!-- Notification : stationnement enregistré -->
    <string name="notif_parking_saved_title">Stationnement enregistré</string>
    <string name="notif_parking_saved_text">Votre voiture a été garée. Appuyez pour la voir sur la carte.</string>

    <!-- Notification : stationnement enregistré + action annuler (remplace l'invite après auto-confirmation) -->
    <string name="notif_parking_saved_confirm_title">Véhicule garé</string>
    <string name="notif_parking_saved_confirm_title_vehicle">%1$s garé</string>
    <string name="notif_parking_saved_confirm_text">Touchez pour ouvrir la carte, ou annulez si ce n\'était pas votre véhicule.</string>
    <string name="notif_action_confirm">Oui, confirmer</string>
    <string name="notif_action_cancel_save">Non, annuler</string>

    <!-- Notification : permission révoquée pendant que le service était actif -->
    <string name="notif_permission_revoked_title">Paparcar a besoin d\'autorisations</string>
    <string name="notif_permission_revoked_text">Permission de localisation révoquée — appuyez pour restaurer</string>

    <!-- Notification : erreur lors de la sauvegarde du stationnement -->
    <string name="notif_confirmation_failed_title">Stationnement non sauvegardé</string>
    <string name="notif_confirmation_failed_text">Impossible de sauvegarder votre place. Ouvrez Paparcar pour réessayer.</string>

    <!-- Notification : debug (builds de développement uniquement) -->
    <string name="notif_debug_title">Paparcar Debug</string>

    <!-- Noms et descriptions des canaux de notification -->
    <string name="channel_detection_name">Détection de places</string>
    <string name="channel_detection_desc">Notification persistante pendant la détection de stationnement</string>
    <string name="channel_upload_name">Upload de places</string>
    <string name="channel_upload_desc">Confirmations de place enregistrée et upload vers le cloud</string>
    <string name="channel_action_name">Confirmation de stationnement</string>
    <string name="channel_action_desc">Vous demande de confirmer si vous êtes garé</string>
    <string name="channel_debug_name">Debug</string>
    <string name="channel_debug_desc">Messages de débogage — builds de développement uniquement</string>

    <string name="attribution_detection_label">Détection de stationnement</string>

    <!-- Notification : watchdog « toujours garé ? » (sortie de géofence probablement manquée) -->
    <string name="notif_still_parked_title">Toujours garé ici ?</string>
    <string name="notif_still_parked_text">Si vous êtes déjà parti, libérez la place pour la communauté.</string>
    <!-- DET-TOGGLE-002: cold-start nudge -->
    <string name="notif_first_park_nudge_title">Garez-vous une fois pour activer la détection</string>
    <string name="notif_first_park_nudge_text">Garez-vous une fois avec Paparcar ; ensuite nous libérons votre place automatiquement à chaque départ.</string>
    <string name="notif_first_park_nudge_action">Marquer ma place</string>
    <!-- DET-AR-FIRST-001 -->
    <string name="notif_mark_parking_title">Où avez-vous laissé votre voiture ?</string>
    <string name="notif_mark_parking_text">Nous avons détecté un déplacement, mais nous n\'avons pas pu déterminer où est restée votre voiture. Marquez la place pour ne pas la perdre.</string>
    <string name="notif_mark_parking_action">Marquer ma place</string>
    <string name="notif_action_ive_left">Je suis parti</string>
    <string name="notif_background_kill_title">Votre téléphone bloque Paparcar</string>
    <string name="notif_background_kill_text">Le système a suspendu la détection de stationnement en arrière-plan pendant des heures. Touchez pour ouvrir l\'appli et corriger dans Réglages → Détection.</string>
</resources>
