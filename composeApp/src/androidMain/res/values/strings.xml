<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Notification: detection foreground service -->
    <string name="notif_detection_title">Parking detection on</string>
    <string name="notif_detection_text">Detecting when you park · tap to manage</string>
    <!-- %1$s = vehicle name (e.g. "Ford Focus") -->
    <string name="notif_detection_text_vehicle">Watching your %1$s · tap to manage</string>
    <string name="notif_detection_explainer">I automatically detect when you park to free your spot for the community. Minimal battery use.</string>

    <!-- Notification: parking confirmation prompt -->
    <string name="notif_confirmation_title">Did you park?</string>
    <string name="notif_confirmation_title_vehicle">Did you park your %1$s?</string>
    <string name="notif_confirmation_text">Looks like you parked. Shall we confirm the spot?</string>
    <string name="notif_action_yes_parked">Yes, I parked</string>
    <string name="notif_action_no_not_parked">No, I haven\'t parked</string>

    <!-- Notification: parking saved (user's own car) -->
    <string name="notif_parking_saved_title">Parking saved</string>
    <string name="notif_parking_saved_text">Your car has been parked. Tap to see it on the map.</string>

    <!-- Notification: parking saved + revert action (replaces the prompt after auto-confirm) -->
    <string name="notif_parking_saved_confirm_title">Vehicle parked</string>
    <!-- %1$s = vehicle name (e.g. "Ford Focus") -->
    <string name="notif_parking_saved_confirm_title_vehicle">%1$s parked</string>
    <string name="notif_parking_saved_confirm_text">Tap to open the map, or cancel if it wasn\'t your vehicle.</string>
    <string name="notif_action_confirm">Yes, confirm</string>
    <string name="notif_action_cancel_save">No, cancel</string>

    <!-- Notification: permission revoked while service was running -->
    <string name="notif_permission_revoked_title">Paparcar needs permissions</string>
    <string name="notif_permission_revoked_text">Location permission revoked — tap to restore</string>

    <!-- Notification: confirmation failed (exceptional error path) -->
    <string name="notif_confirmation_failed_title">Parking not saved</string>
    <string name="notif_confirmation_failed_text">Could not save your parking spot. Open Paparcar to try again.</string>

    <!-- Notification: OEM background-kill warning [OEM-KILL-001] -->
    <string name="notif_background_kill_title">Your phone is blocking Paparcar</string>
    <string name="notif_background_kill_text">The system paused parking detection in the background for hours. Tap to open the app and fix it in Settings → Detection.</string>

    <!-- Notification: watchdog "still parked?" prompt (suspected missed geofence exit) -->
    <string name="notif_still_parked_title">Still parked here?</string>
    <string name="notif_still_parked_text">If you\'ve already driven off, free the spot for the community.</string>
    <!-- DET-TOGGLE-002: cold-start nudge -->
    <string name="notif_first_park_nudge_title">Park once to start auto-detection</string>
    <string name="notif_first_park_nudge_text">Park with Paparcar once — after that we free your spot automatically every time you leave.</string>
    <string name="notif_first_park_nudge_action">Mark my spot</string>
    <!-- DET-AR-FIRST-001: unattended session ended without measured driving — ask where the car is -->
    <string name="notif_mark_parking_title">Where did you leave your car?</string>
    <string name="notif_mark_parking_text">We noticed you moved, but we couldn\'t pin where your car ended up. Mark the spot so you don\'t lose it.</string>
    <string name="notif_mark_parking_action">Mark my spot</string>
    <string name="notif_action_ive_left">I\'ve left</string>

    <!-- Notification: debug (dev builds only) -->
    <string name="notif_debug_title">Paparcar Debug</string>

    <!-- Attribution tag label (required as resource reference by PackageParser) -->
    <string name="attribution_detection_label">Parking detection</string>

    <!-- Notification channel names and descriptions -->
    <string name="channel_detection_name">Spot Detection</string>
    <string name="channel_detection_desc">Persistent notification while parking detection is active</string>
    <string name="channel_upload_name">Parking &amp; Spots</string>
    <string name="channel_upload_desc">Parking saved and spot upload confirmations</string>
    <string name="channel_action_name">Parking confirmation</string>
    <string name="channel_action_desc">Asks you to confirm whether you have parked</string>
    <string name="channel_debug_name">Debug</string>
    <string name="channel_debug_desc">Debug messages — development builds only</string>
</resources>
