<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AppCompat.Light.NoActionBar" parent="Theme.AppCompat.Light">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Native splash (core-splashscreen). windowSplashScreenBackground points to a
         DayNight color so the splash fondo follows light/dark; the in-app ThemeMode
         preference is pushed into AppCompat night mode in PaparcarApp so this resolves
         to the user's choice, not just the system setting. -->
    <style name="Theme.Paparcar.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <!-- DayNight brand badge (splash_glyph + drawable-night variant): the disc is
             baked INTO the drawable — Ink disc + green glyph in day, green disc + Ink glyph
             in night — so the badge stays visible on either splash fondo (mirrors
             PaparcarLogo). windowSplashScreenIconBackgroundColor was dropped because the
             platform splash ignored it here, leaving only the bare glyph. Kept separate
             from ic_launcher_foreground: a night override there would also repaint the
             adaptive launcher icon. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_glyph</item>
        <item name="postSplashScreenTheme">@style/Theme.AppCompat.Light.NoActionBar</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
