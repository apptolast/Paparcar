<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Notificação: serviço foreground de deteção -->
    <string name="notif_detection_title">Deteção de estacionamento ativa</string>
    <string name="notif_detection_text">Deteto quando estacionas · toca para gerir</string>
    <!-- %1$s = nome do veículo (ex. "Ford Focus") -->
    <string name="notif_detection_text_vehicle">Atento ao teu %1$s · toca para gerir</string>
    <string name="notif_detection_explainer">Deteto automaticamente quando estacionas para libertar o teu lugar para a comunidade. Consumo de bateria mínimo.</string>

    <!-- Notificação: confirmação de estacionamento -->
    <string name="notif_confirmation_title">Estacionou?</string>
    <string name="notif_confirmation_title_vehicle">Estacionaste o %1$s?</string>
    <string name="notif_confirmation_text">Parece que estacionou. Queremos confirmar o lugar?</string>
    <string name="notif_action_yes_parked">Sim, estacionei</string>
    <string name="notif_action_no_not_parked">Não, não estacionei</string>

    <!-- Notificação: estacionamento guardado -->
    <string name="notif_parking_saved_title">Estacionamento guardado</string>
    <string name="notif_parking_saved_text">O seu carro foi estacionado. Toque para vê-lo no mapa.</string>

    <!-- Notificação: estacionamento guardado + ação cancelar (substitui o prompt após auto-confirmação) -->
    <string name="notif_parking_saved_confirm_title">Veículo estacionado</string>
    <string name="notif_parking_saved_confirm_title_vehicle">%1$s estacionado</string>
    <string name="notif_parking_saved_confirm_text">Toque para abrir o mapa, ou cancele se não era o seu veículo.</string>
    <string name="notif_action_confirm">Sim, confirmar</string>
    <string name="notif_action_cancel_save">Não, cancelar</string>

    <!-- Notificação: permissão revogada enquanto o serviço estava ativo -->
    <string name="notif_permission_revoked_title">Paparcar precisa de permissões</string>
    <string name="notif_permission_revoked_text">Permissão de localização revogada — toque para restaurar</string>

    <!-- Notificação: erro ao salvar o estacionamento -->
    <string name="notif_confirmation_failed_title">Estacionamento não salvo</string>
    <string name="notif_confirmation_failed_text">Não foi possível salvar a vaga. Abra o Paparcar para tentar novamente.</string>

    <!-- Notificação: debug (apenas builds de desenvolvimento) -->
    <string name="notif_debug_title">Paparcar Debug</string>

    <!-- Nomes e descrições dos canais de notificação -->
    <string name="channel_detection_name">Deteção de Lugar</string>
    <string name="channel_detection_desc">Notificação persistente enquanto a deteção de estacionamento está ativa</string>
    <string name="channel_upload_name">Upload de Lugar</string>
    <string name="channel_upload_desc">Confirmações de lugar guardado e upload para a nuvem</string>
    <string name="channel_action_name">Confirmação de estacionamento</string>
    <string name="channel_action_desc">Pergunta-te se estacionaste</string>
    <string name="channel_debug_name">Debug</string>
    <string name="channel_debug_desc">Mensagens de depuração — apenas em builds de desenvolvimento</string>

    <string name="attribution_detection_label">Deteção de estacionamento</string>

    <!-- Notificação: watchdog "ainda estacionado?" (possível saída de geocerca perdida) -->
    <string name="notif_still_parked_title">Ainda estacionado aqui?</string>
    <string name="notif_still_parked_text">Se já saiu, liberte a vaga para a comunidade.</string>
    <!-- DET-TOGGLE-002: cold-start nudge -->
    <string name="notif_first_park_nudge_title">Estacione uma vez para ativar a deteção</string>
    <string name="notif_first_park_nudge_text">Estacione com o Paparcar uma vez; depois libertamos a sua vaga automaticamente sempre que sair.</string>
    <string name="notif_first_park_nudge_action">Marcar a vaga</string>
    <!-- DET-AR-FIRST-001 -->
    <string name="notif_mark_parking_title">Onde deixou o carro?</string>
    <string name="notif_mark_parking_text">Detetámos que se deslocou, mas não conseguimos fixar onde ficou o seu carro. Marque a vaga para não a perder.</string>
    <string name="notif_mark_parking_action">Marcar a vaga</string>
    <string name="notif_action_ive_left">Já saí</string>
    <string name="notif_background_kill_title">O teu telemóvel está a bloquear o Paparcar</string>
    <string name="notif_background_kill_text">O sistema parou a deteção de estacionamento em segundo plano durante horas. Toca para abrir a app e resolver em Definições → Deteção.</string>
