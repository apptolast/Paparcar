            <gradient
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="108"
                android:type="linear">
                <item android:color="#2196F3" android:offset="0.0" />
                <item android:color="#3F51B5" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

