<?xml version="1.0" encoding="utf-8"?>
<!--
  Paparcar adaptive icon · foreground wrapper.

  The raster foreground (mipmap/ic_launcher_foreground.png) was rendered
  filling the full 108dp adaptive canvas, which makes the car glyph read
  noticeably larger than the artwork of peer apps in the launcher grid.
  Inset 16dp on every side so the car sits inside the inner ~76dp band —
  closer to Android's 72dp adaptive-icon safe zone and visually balanced
  with the wallpaper neighbours.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp"
        android:drawable="@mipmap/ic_launcher_foreground" />
</layer-list>
