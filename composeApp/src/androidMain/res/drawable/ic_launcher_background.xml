<?xml version="1.0" encoding="utf-8"?>
<!--
  Paparcar adaptive icon · background layer.

  Matches the dark-theme surface family from ui/theme/Color.kt. Subtle
  vertical gradient adds depth (mirrors the lighter-top / darker-bottom cue
  from the 2022 source artwork) without breaking the "near-black" reading.

  Token mapping:
    #141918 → PapInkContainer (surfaceContainer — slightly raised tone, top)
    #0B0F0E → PapInk          (surface — app base, bottom)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="108"
                android:startColor="#141918"
                android:endColor="#0B0F0E" />
        </aapt:attr>
    </path>
</vector>
