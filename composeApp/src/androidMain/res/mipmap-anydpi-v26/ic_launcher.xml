<?xml version="1.0" encoding="utf-8"?>
<!--
  Paparcar adaptive icon · combines background + foreground.
  Android 8+ (API 26) uses this; older versions fall back to
  the regular ic_launcher.png in mipmap-*.

  - background: solid neon-green vector
  - foreground: white-ish icon raster, the actual paparcar mark
  - monochrome: for Android 13+ themed icons (reuses foreground)
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
