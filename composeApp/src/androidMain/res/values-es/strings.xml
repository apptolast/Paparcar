<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Notificación: servicio foreground de detección -->
    <string name="notif_detection_title">Detección de aparcamiento activa</string>
    <string name="notif_detection_text">Detectaré cuándo aparcas · toca para gestionar</string>
    <!-- %1$s = nombre del vehículo (ej. "Ford Focus") -->
    <string name="notif_detection_text_vehicle">Atento a tu %1$s · toca para gestionar</string>
    <string name="notif_detection_explainer">Detecto automáticamente cuándo aparcas para liberar tu plaza a la comunidad. Consumo de batería mínimo.</string>

    <!-- Notificación: confirmación de aparcamiento -->
    <string name="notif_confirmation_title">¿Has aparcado?</string>
    <string name="notif_confirmation_title_vehicle">¿Has aparcado el %1$s?</string>
    <string name="notif_confirmation_text">Parece que has aparcado el coche. ¿Confirmamos la plaza?</string>
    <string name="notif_action_yes_parked">Sí, he aparcado</string>
    <string name="notif_action_no_not_parked">No, no he aparcado</string>

    <!-- Notificación: aparcamiento guardado -->
    <string name="notif_parking_saved_title">Aparcamiento guardado</string>
    <string name="notif_parking_saved_text">Tu coche ha sido aparcado. Toca para verlo en el mapa.</string>

    <!-- Notificación: aparcamiento guardado + acción de cancelar (sustituye al prompt tras auto-confirm) -->
    <string name="notif_parking_saved_confirm_title">Vehículo aparcado</string>
    <string name="notif_parking_saved_confirm_title_vehicle">%1$s aparcado</string>
    <string name="notif_parking_saved_confirm_text">Toca para abrir el mapa, o cancela si no era tu vehículo.</string>
    <string name="notif_action_confirm">Sí, confirmar</string>
    <string name="notif_action_cancel_save">No, cancelar</string>

    <!-- Notificación: permiso revocado mientras el servicio estaba activo -->
    <string name="notif_permission_revoked_title">Paparcar necesita permisos</string>
    <string name="notif_permission_revoked_text">Permiso de ubicación revocado — toca para restaurar</string>

    <!-- Notificación: error al guardar el aparcamiento -->
    <string name="notif_confirmation_failed_title">Aparcamiento no guardado</string>
    <string name="notif_confirmation_failed_text">No se pudo guardar tu plaza. Abre Paparcar para intentarlo de nuevo.</string>

    <!-- Notificación: debug (solo builds de desarrollo) -->
    <string name="notif_debug_title">Paparcar Debug</string>

    <!-- Nombres y descripciones de canales de notificación -->
    <string name="channel_detection_name">Detección de Spot</string>
    <string name="channel_detection_desc">Notificación persistente mientras se detecta aparcamiento</string>
    <string name="channel_upload_name">Subida de Spot</string>
    <string name="channel_upload_desc">Confirmaciones de plaza guardada y subida a la nube</string>
    <string name="channel_action_name">Confirmación de aparcamiento</string>
    <string name="channel_action_desc">Te pregunta si has aparcado</string>
    <string name="channel_debug_name">Debug</string>
    <string name="channel_debug_desc">Mensajes de depuración — solo en builds de desarrollo</string>

    <string name="attribution_detection_label">Detección de aparcamiento</string>

    <!-- Notificación: aviso de bloqueo en segundo plano por el fabricante [OEM-KILL-001] -->
    <string name="notif_background_kill_title">Tu móvil está bloqueando Paparcar</string>
    <string name="notif_background_kill_text">El sistema paró la detección de aparcamiento en segundo plano durante horas. Toca para abrir la app y arreglarlo en Ajustes → Detección.</string>

    <!-- Notificación: watchdog "¿sigues aparcado?" (posible salida de geocerca perdida) -->
    <string name="notif_still_parked_title">¿Sigues aparcado aquí?</string>
    <string name="notif_still_parked_text">Si ya te has ido, libera la plaza para la comunidad.</string>
    <!-- DET-TOGGLE-002: cold-start nudge -->
    <string name="notif_first_park_nudge_title">Aparca una vez para activar la detección</string>
    <string name="notif_first_park_nudge_text">Aparca con Paparcar una vez; después liberamos tu plaza automáticamente cada vez que salgas.</string>
    <string name="notif_first_park_nudge_action">Marcar mi plaza</string>
    <string name="notif_action_ive_left">Ya he salido</string>
</resources>
