    <string name="permissions_title">Automatisiere dein Parken</string>
    <string name="permissions_subtitle">Nur der Standort ist erforderlich – der Rest ermöglicht die automatische Erkennung.</string>
    <string name="permissions_perm_location">Genaue Position</string>
    <string name="permissions_perm_location_desc">Um genau zu speichern, wo du dein Fahrzeug geparkt hast</string>
