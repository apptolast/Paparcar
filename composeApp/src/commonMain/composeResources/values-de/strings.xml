    <!-- PermissionsScreen -->
    <string name="permissions_title">Berechtigungen aktivieren</string>
    <string name="permissions_subtitle">Die folgenden Berechtigungen sind für die automatische Erkennung erforderlich.</string>
    <string name="permissions_perm_location">Genaue Position</string>
    <string name="permissions_perm_location_desc">Um genau zu speichern, wo du dein Fahrzeug geparkt hast</string>
    <string name="permissions_perm_background">Hintergrundstandort</string>
    <string name="permissions_perm_background_desc">Erforderlich, um das Parken auch bei geschlossener App zu erkennen</string>
    <string name="permissions_perm_activity">Aktivitätserkennung</string>
    <string name="permissions_perm_activity_desc">Um automatisch zu erkennen, wann du zu fahren beginnst und wann du parkst</string>
    <string name="permissions_perm_notifications">Benachrichtigungen</string>
    <string name="permissions_perm_notifications_desc">Um das Parken zu bestätigen und dich über freie Stellplätze in der Nähe zu informieren</string>
    <string name="permissions_perm_bluetooth">Bluetooth</string>
    <string name="permissions_perm_bluetooth_desc">Ermöglicht die automatische Parkplatzerkennung beim Verbinden oder Trennen vom Bluetooth des Autos</string>
    <string name="permissions_perm_battery">Unbegrenzte Akkunutzung</string>
    <string name="permissions_perm_battery_desc">Verhindert, dass das System die Parkplatzerkennung im Hintergrund beendet. Dringend empfohlen auf Xiaomi-, Oppo- und Huawei-Geraten.</string>
    <string name="permissions_perm_battery_oem_hint">Ihr Geraetehersteller kann auch die Aktivierung von Autostart oder Hintergrundaktivitaet in den Systemeinstellungen erfordern. Ohne diese kann die Erkennung nach einigen Stunden aufhoeren zu funktionieren.</string>
    <string name="permissions_perm_autostart">Autostart / Hintergrundaktivitaet</string>
    <string name="permissions_perm_autostart_desc">Optional — die App funktioniert auch ohne, aber auf Xiaomi-, OPPO- und Huawei-Geraeten kann die Parkerkennung nach einigen Stunden ausfallen. Das Aktivieren ermoeglicht der App, zuverlaessig aufzuwachen. Minimale Auswirkung auf den Akku.</string>
    <string name="permissions_perm_oem_battery">Hintergrund-Energiesparmodus</string>
    <string name="permissions_perm_oem_battery_desc">Optional — Ihr OPPO/Realme-Geraet kann Apps im Hintergrund einfrieren. Ohne dies kann GPS waehrend der Erkennung ausfallen. Deaktivieren Sie den Energiesparmodus fuer Paparcar in den Akkueinstellungen. Minimale Auswirkung auf den Akku.</string>
