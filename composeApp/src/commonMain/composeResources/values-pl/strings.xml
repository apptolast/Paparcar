    <string name="permissions_title">Zautomatyzuj parkowanie</string>
    <string name="permissions_subtitle">Wymagana jest tylko lokalizacja — reszta umożliwia automatyczne wykrywanie.</string>
    <string name="permissions_perm_location">Dokładna lokalizacja</string>
