rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Spots — recurso comunitario. [AUDIT-RULES-001 C4 + A4-rules]
    //   - read:   cualquier autenticado (todos ven plazas cercanas).
    //   - create: sólo si el spot se firma con el UID del creador (reportedBy == uid).
    //   - update: el dueño puede editar cualquier campo; CUALQUIER otro autenticado sólo puede
    //             tocar los contadores comunitarios (enRouteCount / acceptCount / rejectCount) y
    //             nunca reasignar reportedBy — cierra el "cualquiera reescribe el spot ajeno".
    //   - delete: el dueño, O cualquiera si el spot YA CADUCÓ (expiresAt < ahora) — un TTL
    //             server-side barato sin Cloud Functions que evita que la colección crezca sin fin.
    match /spots/{spotId} {
      allow read:   if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.reportedBy == request.auth.uid;

      allow update: if request.auth != null
                    && (
                         // El dueño edita libremente, pero no puede cambiar de dueño.
                         (resource.data.reportedBy == request.auth.uid
                          && request.resource.data.reportedBy == resource.data.reportedBy)
                         // Un tercero sólo puede tocar los contadores comunitarios.
                         || request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['enRouteCount', 'acceptCount', 'rejectCount'])
                       );

      allow delete: if request.auth != null
                    && (resource.data.reportedBy == request.auth.uid
                        // .get(..,0): un spot sin expiresAt (legacy) cuenta como caducado.
                        || resource.data.get('expiresAt', 0) < request.time.toMillis());
    }

    // Perfil de usuario y todas sus subcollections — sólo el propio usuario.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /vehicles/{vehicleId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /parkingHistory/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /zones/{zoneId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Diagnostics — trazas de detección en campo (DET-LOG). Sólo el propio usuario escribe/lee
    // las suyas. Default OFF vía el flag de abajo; sin opt-in no se escribe nada.
    match /diagnostics/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Flag de diagnóstico por usuario. El cliente sólo LO LEE para auto-gatearse; el toggle
    // lo hace un admin (MCP / Admin SDK, que bypassa estas reglas), nunca el cliente.
    match /diagnostics_config/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Denegar cualquier otra colección no listada explícitamente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
