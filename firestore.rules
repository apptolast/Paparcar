rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Spots — recurso comunitario; cualquier usuario autenticado puede leer y escribir.
    // Los campos enRouteCount / acceptCount / rejectCount los actualiza la comunidad.
    // Delete: sólo el reportador o spots anónimos (auto-detectados sin UID).
    match /spots/{spotId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && (resource.data.reportedBy == request.auth.uid
                        || resource.data.reportedBy == "anonymous");
    }

    // Perfil de usuario y todas sus subcollections — sólo el propio usuario.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /vehicles/{vehicleId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /parkingHistory/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /zones/{zoneId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Diagnostics — trazas de detección en campo (DET-LOG). Sólo el propio usuario escribe/lee
    // las suyas. Default OFF vía el flag de abajo; sin opt-in no se escribe nada.
    match /diagnostics/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Flag de diagnóstico por usuario. El cliente sólo LO LEE para auto-gatearse; el toggle
    // lo hace un admin (MCP / Admin SDK, que bypassa estas reglas), nunca el cliente.
    match /diagnostics_config/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Denegar cualquier otra colección no listada explícitamente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
